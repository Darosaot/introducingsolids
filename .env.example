# --- Frontend (safe to expose, embedded in the built bundle) ---
# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase "anon" / publishable public key (safe for the browser; RLS protects data)
VITE_SUPABASE_ANON_KEY=

# --- Netlify serverless functions ONLY (NEVER prefix with VITE_, never sent to the browser) ---
# Supabase service-role secret key. Used exclusively by netlify/functions/admin-users
# to let admins create / disable / delete auth users. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=

# Same value as VITE_SUPABASE_URL, made available to the serverless function runtime.
SUPABASE_URL=
